# ===============================
# APPLICATION
# ===============================
PORT=3000
NODE_ENV=development

# ===============================
# DATABASE (TypeORM + PostgreSQL)
# ===============================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=nestjs_db
DB_SYNCHRONIZE=true
DB_LOGGING=false

# ===============================
# JWT
# Secret keys must be at least 32 characters
# Access expire: milliseconds (900000 = 15 minutes)
# Refresh expire: milliseconds (604800000 = 7 days)
# ===============================
JWT_ACCESS_SECRET=aXZuHZSrxo0gHRWe01sjNyH86OBg1AbP
JWT_REFRESH_SECRET=aXZuHZSrxo0gHRWe01sjNyH86OBg2AbP
JWT_ACCESS_EXPIRE_MS=900000
JWT_REFRESH_EXPIRE_MS=604800000

# ===============================
# REDIS (Optional — token blacklisting & user caching)
# Set REDIS_ENABLED=true to enable
# ===============================
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
JWT_CACHE_TTL_MS=3600000

# ===============================
# METADATA DATABASE (Tenant Config Storage)
# ===============================
METADATA_DB_HOST=localhost
METADATA_DB_PORT=5432
METADATA_DB_USERNAME=postgres
METADATA_DB_PASSWORD=postgres
METADATA_DB_NAME=erp-tenant

# ===============================
# TENANT POOL SETTINGS
# ===============================
TENANT_POOL_MIN=5
TENANT_POOL_MAX=20
TENANT_POOL_IDLE_MS=600000
TENANT_POOL_EVICTION_MS=3600000
TENANT_POOL_CONNECT_TIMEOUT=30000
